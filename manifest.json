{
  "manifest_version": 3,
  "name": "FloatVid – Picture in Picture",
  "short_name": "FloatVid",
  "version": "1.0.1",
  "description": "Float any video in a resizable, always-on-top window.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "pip-shared.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "pip-shared.js",
        "youtube.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_title": "FloatVid – Toggle Picture-in-Picture"
  },
  "options_ui": {
    "page": "dist/options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "toggle-pip": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Command+Shift+P",
        "windows": "Ctrl+Shift+P"
      },
      "description": "Toggle Picture-in-Picture"
    }
  }
}